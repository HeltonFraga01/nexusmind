# NexusMind — Swarm env (nexusmind.digital)
# Uso:
#   cp nexusmind/deploy/stack.swarm.nexusmind.digital.env.example .env.nexusmind
#   export $(grep -v '^#' .env.nexusmind | xargs)
#   docker stack deploy -c nexusmind/deploy/stack.swarm.nexusmind.digital.yml nexusmind

NEXUSMIND_IMAGE=heltonfraga/nexusmind:latest
SWARM_STATEFUL_NODE=manager-1
TRAEFIK_NETWORK=network_public

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_USER=nexusmind
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=nexusmind
DATABASE_SSLMODE=disable
# Limite de conexões do Postgres. Precisa ser >= 2x DATABASE_MAX_OPEN_CONNS
# (deploy start-first roda 2 containers do app simultaneamente).
POSTGRES_MAX_CONNECTIONS=200
DATABASE_MAX_OPEN_CONNS=80
DATABASE_MAX_IDLE_CONNS=20

REDIS_IMAGE=redis:8-alpine
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

ADMIN_EMAIL=admin@nexusmind.digital
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
TOTP_ENCRYPTION_KEY=CHANGE_ME_LONG_RANDOM_HEX
JWT_EXPIRE_HOUR=24

SERVER_MODE=release
RUN_MODE=standard
TZ=America/Sao_Paulo

WEBHOOK_BASE_URL=https://nexusmind.digital
CORS_ALLOWED_ORIGINS=https://nexusmind.digital

# Confia no Traefik (overlay do Swarm) para ler o IP real do cliente.
SERVER_TRUSTED_PROXIES=10.0.0.0/8

# Hardening de SSRF: só HTTPS e bloqueia hosts de rede privada nas URLs
# de upstream. Mude para true se precisar de um upstream HTTP ou interno.
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
