# ============================================================================
# Sub2API Swarm env example
# Use: cp deploy/stack.swarm.env.example .env.swarm && editar valores reais
# Deploy: export $(grep -v '^#' .env.swarm | xargs) && docker stack deploy -c deploy/stack.swarm.yml sub2api
# ============================================================================

# Required runtime image
SUB2API_IMAGE=ghcr.io/your-org/sub2api:your-tag

# Swarm placement (stateful node)
SWARM_STATEFUL_NODE=manager-1

# Database
POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sub2api
DATABASE_SSLMODE=disable

# Redis
REDIS_IMAGE=redis:8-alpine
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# Admin bootstrap (first-run)
ADMIN_EMAIL=admin@route-cortexx.local
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Security secrets
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
TOTP_ENCRYPTION_KEY=CHANGE_ME_LONG_RANDOM_HEX
JWT_EXPIRE_HOUR=24

# Server
SERVER_MODE=release
RUN_MODE=standard
TZ=UTC
SERVER_PUBLISHED_PORT=8080

# DB pool
DATABASE_MAX_OPEN_CONNS=80
DATABASE_MAX_IDLE_CONNS=20
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# Optional flags
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=
UPDATE_PROXY_URL=
